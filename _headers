
# Long-term caching for all static assets
/images/*
  Cache-Control: public, max-age=31536000, immutable

/images1/*
  Cache-Control: public, max-age=31536000, immutable

/images3/*
  Cache-Control: public, max-age=31536000, immutable

/images4/*
  Cache-Control: public, max-age=31536000, immutable

/images5/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate so new deploys are picked up
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Fonts
https://fonts.googleapis.com/*
  Cache-Control: public, max-age=31536000, immutable

# Enable Brotli/Gzip compression (Netlify applies this automatically)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
